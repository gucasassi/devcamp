# Server Configuration
APP_PORT=3010
NODE_ENV=development

# Database Configuration
# Use a placeholder for sensitive information like username and password
MONGODB_URI=mongodb+srv://<username>:<password>@<host>/<database>?retryWrites=true&w=majority

# Geocoder Service Configuration
GEOCODER_API_KEY=<your_mapquest_api_key>
GEOCODER_PROVIDER=mapquest

# JWT Configuration
JWT_SECRET=<your_secret>
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# File path configuration
MAX_FILE_UPLOAD=1000000
FILE_UPLOAD_PATH=./public/uploads

# SMTP configuration
SMTP_HOST=<your_smtp_service_host>
SMTP_PORT=<your_smtp_service_port>
SMTP_USER=<your_smtp_service_user>
SMTP_PASSWORD=<your_smtp_service_port>
FROM_NAME=DevCamper
FROM_EMAIL=noreply@your_domain.com